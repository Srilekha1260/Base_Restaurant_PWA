# Backend API
DATABASE_URL="postgresql://postgres:password@localhost:5432/restaurant_platform"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Frontend apps (prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_STAFF_URL="http://localhost:3001"
NEXT_PUBLIC_KITCHEN_URL="http://localhost:3002"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3003"

# Azure (production)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="restaurant-assets"
