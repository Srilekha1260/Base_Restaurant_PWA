# ─── Production env reference (do NOT commit real values) ───────────────────

# === API (set these in Render) ===
DATABASE_URL=postgresql://...neon-pooled-url...
JWT_SECRET=<auto-generated by Render>
JWT_REFRESH_SECRET=<auto-generated by Render>
STRIPE_SECRET_KEY=sk_test_xxx
# Optional email (Resend). Leave unset to log emails instead of sending.
RESEND_API_KEY=
ORDER_FROM_EMAIL=Demo Restaurant <onboarding@resend.dev>
# The deployed Vercel frontend URLs (CORS). Fill after deploying frontends.
WEB_URL=https://restaurant-web.vercel.app
STAFF_URL=https://restaurant-staff.vercel.app
KITCHEN_URL=https://restaurant-kitchen.vercel.app
ADMIN_URL=https://restaurant-admin.vercel.app

# === Each Vercel frontend (set per project) ===
# All four apps:
NEXT_PUBLIC_API_URL=https://restaurant-api.onrender.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://restaurant-api.onrender.com
# web app only:
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
